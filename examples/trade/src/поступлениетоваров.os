Процедура ПриЗаписи()
  Если this.Номер = "" Тогда
    Error("Укажите номер документа");
  КонецЕсли;
  Если this.Поставщик = "" Тогда
    Error("Укажите поставщика");
  КонецЕсли;
  Если this.Склад = "" Тогда
    Error("Укажите склад");
  КонецЕсли;

  Движения.ОстаткиТоваров.Очистить();
  Движения.Взаиморасчеты.Очистить();

  ИтогСумма = 0;

  Для Каждого Строка Из this.Товары Цикл
    Строка.Сумма = Строка.Количество * Строка.Цена;
    ИтогСумма = ИтогСумма + Строка.Сумма;

    Дв = Движения.ОстаткиТоваров.Добавить();
    Дв.ВидДвижения  = "Приход";
    Дв.Номенклатура = Строка.Номенклатура;
    Дв.Склад        = this.Склад;
    Дв.Количество   = Строка.Количество;
    Дв.Сумма        = Строка.Сумма;
  КонецЦикла;

  Дв = Движения.Взаиморасчеты.Добавить();
  Дв.ВидДвижения    = "Расход";
  Дв.Контрагент     = this.Поставщик;
  Дв.ТипКонтрагента = "Поставщик";
  Дв.Сумма          = ИтогСумма;
КонецПроцедуры
